<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item
        android:bottom="-4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="#40991B1B" />
        </shape>
    </item>
    <!-- Main button -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="@color/sos_red_dark"
                android:startColor="@color/sos_red"
                android:type="linear" />
        </shape>
    </item>
    <!-- Inner highlight -->
    <item
        android:bottom="50dp"
        android:left="15dp"
        android:right="15dp"
        android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#30FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
