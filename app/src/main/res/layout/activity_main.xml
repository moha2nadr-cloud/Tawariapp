<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:layoutDirection="rtl">

    <!-- Premium Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/background_secondary"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/networkName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                
                android:text=""
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Connection Status Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_status_badge"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <View
                android:id="@+id/connectionDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/dot_red" />

            <TextView
                android:id="@+id/connectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                
                android:text="@string/status_disconnected"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- SwipeRefresh + Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- Not Connected Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/notConnectedCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/error_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/error_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="32dp">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_wifi_off"
                            app:tint="@color/error" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            
                            android:text="@string/network_offline"
                            android:textColor="@color/error"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            
                            android:gravity="center"
                            android:text="@string/network_offline_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- TAB 0: EMERGENCY -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/emergencyContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <!-- Location Status Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_premium"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/locationIcon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_location_off"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/locationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            
                            android:text="@string/location_detecting"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- SOS Button Section -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:gravity="center">

                        <!-- Animated Ring -->
                        <View
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:background="@drawable/sos_ring_premium" />

                        <!-- SOS Button -->
                        <Button
                            android:id="@+id/sosButton"
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_gravity="center"
                            android:background="@drawable/sos_button_premium"
                            android:elevation="12dp"
                            
                            
                            android:text="@string/sos_title"
                            android:textColor="@color/white"
                            android:textSize="36sp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        
                        android:text="@string/sos_hint"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />

                    <!-- Emergency Types Section -->
                    <TextView
                        style="@style/SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="@string/select_emergency_type" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:columnCount="3"
                        android:rowCount="2">

                        <Button
                            android:id="@+id/btnFire"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_fire"
                            
                            
                            android:text="@string/type_fire"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnInjury"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_injury"
                            
                            
                            android:text="@string/type_injury"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnThreat"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_threat"
                            
                            
                            android:text="@string/type_threat"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnAccident"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_accident"
                            
                            
                            android:text="@string/type_accident"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnTrapped"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_trapped"
                            
                            
                            android:text="@string/type_trapped"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnOther"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_type_other"
                            
                            
                            android:text="@string/type_other"
                            android:textColor="@color/white"
                            android:textSize="15sp" />
                    </GridLayout>
                </LinearLayout>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- TAB 1: REPORTS -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/reportsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_active_reports" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/reportsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:id="@+id/emptyReports"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="48dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:alpha="0.3"
                            android:src="@drawable/ic_reports"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            
                            android:text="@string/empty_reports"
                            android:textColor="@color/text_tertiary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            
                            android:text="@string/empty_reports_desc"
                            android:textColor="@color/text_disabled"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- TAB 2: CONTACT -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/contactContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_emergency_agents" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/agentsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:id="@+id/emptyAgents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="48dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:alpha="0.3"
                            android:src="@drawable/ic_contact"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            
                            android:text="@string/empty_agents"
                            android:textColor="@color/text_tertiary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            
                            android:text="@string/empty_agents_desc"
                            android:textColor="@color/text_disabled"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- TAB 3: INFO -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/infoContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_safety_tips" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/contentRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:id="@+id/emptyContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="48dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:alpha="0.3"
                            android:src="@drawable/ic_info"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            
                            android:text="@string/empty_content"
                            android:textColor="@color/text_tertiary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            
                            android:text="@string/empty_content_desc"
                            android:textColor="@color/text_disabled"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Premium Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@color/nav_background"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/tabEmergency"
            style="@style/NavTab"
            android:layout_weight="1">

            <ImageView
                style="@style/NavTabIcon"
                android:src="@drawable/ic_emergency" />

            <TextView
                style="@style/NavTabText"
                android:text="@string/tab_emergency" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabReports"
            style="@style/NavTab"
            android:layout_weight="1">

            <ImageView
                style="@style/NavTabIcon"
                android:src="@drawable/ic_reports" />

            <TextView
                style="@style/NavTabText"
                android:text="@string/tab_reports" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabContact"
            style="@style/NavTab"
            android:layout_weight="1">

            <ImageView
                style="@style/NavTabIcon"
                android:src="@drawable/ic_contact" />

            <TextView
                style="@style/NavTabText"
                android:text="@string/tab_contact" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabInfo"
            style="@style/NavTab"
            android:layout_weight="1">

            <ImageView
                style="@style/NavTabIcon"
                android:src="@drawable/ic_info" />

            <TextView
                style="@style/NavTabText"
                android:text="@string/tab_info" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                
                android:text="جاري الإرسال..."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
